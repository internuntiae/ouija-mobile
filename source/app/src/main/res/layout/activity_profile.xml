<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/customWindowBackground">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="40dp"
        android:paddingBottom="28dp"
        android:background="?attr/customSurface">

        <TextView
            android:id="@+id/tvInitials"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_avatar_large"
            android:gravity="center"
            android:textColor="?attr/customTextPrimary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:id="@+id/tvNickname"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/customTextPrimary"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="14dp"/>

        <TextView
            android:id="@+id/tvEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/customTextSecondary"
            android:textSize="14sp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Logout -->
    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="16dp"
        android:text="@string/btn_logout"
        android:textColor="?attr/customTextPrimary"
        android:background="@drawable/bg_button_danger"
        android:textSize="15sp"/>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/customSurface"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="?attr/customTextPrimary"
        app:itemTextColor="?attr/customTextPrimary"/>

</LinearLayout>
