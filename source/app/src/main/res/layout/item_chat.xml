<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="10dp"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground">

    <!-- Avatar container with initials + optional photo -->
    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp">

        <!-- Initials fallback -->
        <TextView
            android:id="@+id/tvInitials"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_avatar"
            android:gravity="center"
            android:textColor="?attr/customTextPrimary"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"/>

        <!-- Avatar image (hidden when no avatar loaded) -->
        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_avatar"
            android:clipToOutline="true"
            android:visibility="gone"
            android:contentDescription="Avatar"/>

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvChatName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/customTextPrimary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:singleLine="true"/>

        <TextView
            android:id="@+id/tvChatType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/customTextSecondary"
            android:textSize="13sp"
            android:singleLine="true"/>

    </LinearLayout>

</LinearLayout>
