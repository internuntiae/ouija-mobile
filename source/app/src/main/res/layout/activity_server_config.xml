<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/customWindowBackground"
    android:padding="24dp">

    <LinearLayout
        android:id="@+id/card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="28dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.4">

        <TextView
            android:text="@string/server_config_title"
            android:textColor="?attr/customTextPrimary"
            android:textSize="26sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="@string/server_config_subtitle"
            android:textColor="?attr/customTextSecondary"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="28dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="@string/label_server_url"
            android:textColor="?attr/customTextTertiary"
            android:textSize="13sp"
            android:layout_marginBottom="6dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/etServerUrl"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="@string/hint_server_url"
            android:textColorHint="?attr/customHintColor"
            android:textColor="?attr/customTextPrimary"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textUri"
            android:layout_marginBottom="20dp"
            android:autofillHints="url" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_connect"
            android:textColor="?attr/customOnPrimary"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_button_primary"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
