<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.ouija_mobile">

    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:label="Ouija"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.App.Starting"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".ServerConfigActivity"
            android:exported="true"
            android:theme="@style/Theme.Ouija"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.Ouija"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".RegisterActivity"
            android:theme="@style/Theme.Ouija"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".ChatsActivity"
            android:theme="@style/Theme.Ouija"
            android:exported="false"/>

        <activity
            android:name="com.example.ouija_mobile.ChatActivity"
            android:theme="@style/Theme.Ouija.Chat"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ChatsActivity"/>

        <activity
            android:name=".ProfileActivity"
            android:theme="@style/Theme.Ouija"
            android:exported="false"/>

    </application>

</manifest>