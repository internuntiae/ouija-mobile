<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenBackground">#111111</item>
        <item name="postSplashScreenTheme">@style/Theme.Ouija</item>
    </style>

    <!-- Base helper macro -->
    <style name="Theme.Ouija.Base" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">?attr/customPrimary</item>
        <item name="colorOnPrimary">?attr/customOnPrimary</item>
        <item name="android:windowBackground">?attr/customWindowBackground</item>
        <item name="android:statusBarColor">?attr/customWindowBackground</item>
        <item name="android:navigationBarColor">?attr/customSurface</item>
    </style>

    <!-- ── Dark (default) ─────────────────────────────────────────── -->
    <style name="Theme.Ouija" parent="Theme.Ouija.Base">
        <item name="customWindowBackground">@color/dark_window_background</item>
        <item name="customSurface">@color/dark_surface</item>
        <item name="customCardBackground">@color/dark_card_background</item>
        <item name="customInputBackground">@color/dark_input_background</item>
        <item name="customTextPrimary">@color/dark_text_primary</item>
        <item name="customTextSecondary">@color/dark_text_secondary</item>
        <item name="customTextTertiary">@color/dark_text_tertiary</item>
        <item name="customHintColor">@color/dark_hint</item>
        <item name="customPrimary">@color/dark_primary</item>
        <item name="customOnPrimary">@color/dark_on_primary</item>
        <item name="customDangerBackground">@color/dark_danger_background</item>
        <item name="customDangerStroke">@color/dark_danger_stroke</item>
        <item name="customDangerText">@android:color/white</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- ── Light ──────────────────────────────────────────────────── -->
    <style name="Theme.Ouija.Light" parent="Theme.Ouija.Base">
        <item name="customWindowBackground">@color/light_window_background</item>
        <item name="customSurface">@color/light_surface</item>
        <item name="customCardBackground">@color/light_card_background</item>
        <item name="customInputBackground">@color/light_input_background</item>
        <item name="customTextPrimary">@color/light_text_primary</item>
        <item name="customTextSecondary">@color/light_text_secondary</item>
        <item name="customTextTertiary">@color/light_text_tertiary</item>
        <item name="customHintColor">@color/light_hint</item>
        <item name="customPrimary">@color/light_primary</item>
        <item name="customOnPrimary">@color/light_on_primary</item>
        <item name="customDangerBackground">@color/light_danger_background</item>
        <item name="customDangerStroke">@color/light_danger_stroke</item>
        <item name="customDangerText">@color/light_danger_stroke</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- ── Midnight Blue ──────────────────────────────────────────── -->
    <style name="Theme.Ouija.Midnight" parent="Theme.Ouija.Base">
        <item name="customWindowBackground">@color/midnight_window_background</item>
        <item name="customSurface">@color/midnight_surface</item>
