        <item name="customOnPrimary">@color/midnight_on_primary</item>
        <item name="customDangerBackground">@color/midnight_danger_background</item>
        <item name="customDangerStroke">@color/midnight_danger_stroke</item>
        <item name="customDangerText">@android:color/white</item>
        <item name="android:windowLightStatusBar">false</item>
