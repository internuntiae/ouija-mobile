<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/customWindowBackground">

    <!-- Top bar with back button + avatar + chat name -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="?attr/customSurface"
        android:paddingHorizontal="8dp"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="@string/desc_back"
            app:tint="?attr/customTextPrimary"/>

        <!-- Avatar container: initials + optional photo -->
        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="4dp">

            <TextView
                android:id="@+id/tvChatInitials"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_avatar"
                android:gravity="center"
                android:textColor="?attr/customTextPrimary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"/>

            <ImageView
                android:id="@+id/ivChatAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_avatar"
                android:visibility="gone"
                android:contentDescription="Avatar rozmówcy"/>

        </FrameLayout>

        <TextView
            android:id="@+id/tvChatName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:textColor="?attr/customTextPrimary"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium"
            android:singleLine="true"/>

    </LinearLayout>

    <!-- Message list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingVertical="8dp"
        android:paddingHorizontal="12dp" />

    <!-- Pending attachments preview -->
    <HorizontalScrollView
        android:id="@+id/scrollPendingFiles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="?attr/customSurface"
        android:paddingHorizontal="12dp"
        android:paddingTop="6dp">

        <LinearLayout
            android:id="@+id/llPendingFiles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"/>

    </HorizontalScrollView>

    <!-- Message input bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="?attr/customSurface"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:gravity="center_vertical">

        <!-- Attach file button -->
        <ImageButton
            android:id="@+id/btnAttach"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_add"
            android:contentDescription="Załącz plik"
            android:layout_marginEnd="4dp"
            app:tint="?attr/customTextSecondary"/>

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:hint="@string/hint_message"
            android:textColorHint="?attr/customHintColor"
            android:textColor="?attr/customTextPrimary"
            android:paddingHorizontal="16dp"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="3" />

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_send_button"
            android:src="@android:drawable/ic_menu_send"
            android:contentDescription="@string/desc_send"
            app:tint="?attr/customOnPrimary" />

    </LinearLayout>

</LinearLayout>
