<resources>
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenBackground">#111111</item>
        <item name="postSplashScreenTheme">@style/Theme.Ouija</item>
    </style>

    <style name="Theme.Ouija" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Custom attributes -->
        <item name="customWindowBackground">@color/light_window_background</item>
        <item name="customSurface">@color/light_surface</item>
        <item name="customCardBackground">@color/light_card_background</item>
        <item name="customInputBackground">@color/light_input_background</item>
        <item name="customTextPrimary">@color/light_text_primary</item>
        <item name="customTextSecondary">@color/light_text_secondary</item>
        <item name="customTextTertiary">@color/light_text_tertiary</item>
        <item name="customHintColor">@color/light_hint</item>
        <item name="customPrimary">@color/light_primary</item>
        <item name="customOnPrimary">@color/light_on_primary</item>
        <item name="customDangerBackground">@color/light_danger_background</item>
        <item name="customDangerStroke">@color/light_danger_stroke</item>

        <!-- Standard attributes -->
        <item name="colorPrimary">?attr/customPrimary</item>
        <item name="colorOnPrimary">?attr/customOnPrimary</item>
        <item name="android:windowBackground">?attr/customWindowBackground</item>
        <item name="android:statusBarColor">?attr/customWindowBackground</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">?attr/customSurface</item>
    </style>

    <style name="Theme.Ouija.Chat" parent="Theme.Ouija">
    </style>
</resources>